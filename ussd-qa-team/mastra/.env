# OpenAI API Key for agent LLM
OPENAI_API_KEY=sk-your-key-here

# USSDGW test tool paths
USSDGW_MAP_LIB=/opt/ussdgw-test/map-level/lib
USSDGW_HTTP_JAR=/opt/ussdgw-test/http-level/lib/loadtest.jar
USSDGW_GRPC_SCRIPT=/opt/ussdgw-test/scripts/05-start-grpc-as.sh
USSDGW_GATEWAY_COMPOSE=/opt/ussdgw-test/gateway

# Test defaults
DEFAULT_MAP_TPS=10000
DEFAULT_MAX_CONCURRENT=50000
DEFAULT_TEST_DURATION=300
DEFAULT_USSD_STRING="*100#"

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
