# ----------------------------------------------------------------------
# OpenAI / OpenAI-Compatible LLM Configuration
# ----------------------------------------------------------------------
# Option A — Official OpenAI (default)
OPENAI_API_KEY=sk-your-key-here

# Option B — OpenAI-Compatible Provider (Ollama, LM Studio, vLLM, OpenRouter, ...)
# Uncomment and set your endpoint:
# OPENAI_BASE_URL=https://api.openai.com/v1               # Official (default)
# OPENAI_BASE_URL=http://localhost:11434/v1                # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1                 # LM Studio
# OPENAI_BASE_URL=http://localhost:8000/v1                 # vLLM / LocalAI
# OPENAI_BASE_URL=https://openrouter.ai/api/v1             # OpenRouter
#
# When using a compatible provider, the model id in agents (e.g. openai/gpt-4o)
# must match a model name available at your provider:
#   openai/gpt-4o        → works on OpenRouter with your key
#   openai/llama3.1:70b  → works on OpenRouter, Groq, etc.
#   openai/qwen2.5:32b   → works on LM Studio / vLLM if loaded
# ----------------------------------------------------------------------

# USSDGW test tool paths (auto-detected from PKG_ROOT — uncomment to override)
# PKG_ROOT is auto-detected by walking up from cwd to find VERSION + scripts/env.sh.
# Set explicitly only if running from outside the package directory:
# PKG_ROOT=/path/to/ussdgw-prod-release
#
# Override individual tool paths (rarely needed):
# USSDGW_MAP_LIB=${PKG_ROOT}/tools/jss7-map-load/lib
# USSDGW_HTTP_JAR=${PKG_ROOT}/http-level/lib/loadtest.jar
# USSDGW_GRPC_SCRIPT=${PKG_ROOT}/scripts/05-start-grpc-as.sh
# USSDGW_GATEWAY_COMPOSE=${PKG_ROOT}/gateway

# Test defaults
DEFAULT_MAP_TPS=10000
DEFAULT_MAX_CONCURRENT=50000
DEFAULT_TEST_DURATION=300
DEFAULT_USSD_STRING="*100#"

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
